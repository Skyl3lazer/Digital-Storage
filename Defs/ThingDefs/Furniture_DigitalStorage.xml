<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef Name="DigitalStorageShelfBase" ParentName="AdaptiveStorageBase" Abstract="True">
    <designationCategory>Furniture</designationCategory>
    <tickerType>Normal</tickerType>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <statBases>
      <Flammability>1.0</Flammability>
      <Beauty>0.5</Beauty>
    </statBases>
    <building>
      <storageGroupTag>DigitalStorageShelf</storageGroupTag>
      <fixedStorageSettings>
        <filter>
          <categories Inherit="False">
            <li>Books</li>
          </categories>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <categories>
            <li>Books</li>
          </categories>
        </filter>
      </defaultStorageSettings>
    </building>
    <comps>
      <li Class="CompProperties_Flickable" />
    </comps>
  </ThingDef>

  <ThingDef ParentName="DigitalStorageShelfBase">
    <defName>DS_MicrofilmReader</defName>
    <label>microfilm reader</label>
    <description>An industrial reader that compresses written works onto strips of microfilm. Holds far more than a bookcase and still lets colonists study nearby, but only while powered.</description>
    <graphicData>
      <texPath>Things/Building/DigitalStorage/MicrofilmReader</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <costStuffCount>20</costStuffCount>
    <costList>
      <Steel>25</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <Mass>8</Mass>
      <WorkToBuild>150</WorkToBuild>
    </statBases>
    <researchPrerequisites Inherit="False">
      <li>DigitalStorage</li>
    </researchPrerequisites>
    <building>
      <maxItemsInCell>40</maxItemsInCell>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>25</basePowerConsumption>
      </li>
    </comps>
    <modExtensions>
      <li Class="DigitalStorage.DigitalShelfExtension">
        <readingBonusPerBook>0.2</readingBonusPerBook>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="DigitalStorageShelfBase">
    <defName>DS_DigitizedIndex</defName>
    <label>digitized index</label>
    <description>A double-width cabinet of indexed microfilm reels. Stores a large reference library in a compact footprint and supports nearby study, as long as it has power.</description>
    <graphicData>
      <texPath>Things/Building/DigitalStorage/DigitizedIndex</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,2)</drawSize>
    </graphicData>
    <size>(1,2)</size>
    <costStuffCount>50</costStuffCount>
    <costList>
      <Steel>50</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <Mass>16</Mass>
      <WorkToBuild>250</WorkToBuild>
    </statBases>
    <researchPrerequisites Inherit="False">
      <li>DigitalStorage</li>
    </researchPrerequisites>
    <building>
      <maxItemsInCell>40</maxItemsInCell>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>50</basePowerConsumption>
      </li>
    </comps>
    <modExtensions>
      <li Class="DigitalStorage.DigitalShelfExtension">
        <readingBonusPerBook>0.2</readingBonusPerBook>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="DigitalStorageShelfBase">
    <defName>DS_PawnPediaTerminal</defName>
    <label>PawnPedia terminal</label>
    <description>A searchable database terminal that surfaces exactly the right passage on demand. Its curated cross-referencing makes study noticeably more effective than browsing shelves, while powered.</description>
    <graphicData>
      <texPath>Things/Building/DigitalStorage/PawnPediaTerminal</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <stuffCategories Inherit="False">
      <li>Metallic</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>50</costStuffCount>
    <costList>
      <Steel>100</Steel>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <Mass>10</Mass>
      <WorkToBuild>250</WorkToBuild>
    </statBases>
    <researchPrerequisites Inherit="False">
      <li>Databases</li>
    </researchPrerequisites>
    <building>
      <maxItemsInCell>80</maxItemsInCell>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>50</basePowerConsumption>
      </li>
    </comps>
    <modExtensions>
      <li Class="DigitalStorage.DigitalShelfExtension">
        <readingBonusPerBook>0.3</readingBonusPerBook>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="DigitalStorageShelfBase">
    <defName>DS_DigitalOcean</defName>
    <label>digital ocean</label>
    <description>A bank of high-density storage arrays holding an immense sea of digitized works. Includes a primitive assistant AI to find exactly the book you want, when you want it.</description>
    <graphicData>
      <texPath>Things/Building/DigitalStorage/DigitalOcean</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,2)</drawSize>
    </graphicData>
    <size>(1,2)</size>
    <stuffCategories Inherit="False">
      <li>Metallic</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>100</costStuffCount>
    <costList>
      <Steel>100</Steel>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <statBases>
      <MaxHitPoints>220</MaxHitPoints>
      <Mass>20</Mass>
      <WorkToBuild>500</WorkToBuild>
    </statBases>
    <researchPrerequisites Inherit="False">
      <li>Databases</li>
    </researchPrerequisites>
    <building>
      <maxItemsInCell>100</maxItemsInCell>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>150</basePowerConsumption>
      </li>
    </comps>
    <modExtensions>
      <li Class="DigitalStorage.DigitalShelfExtension">
        <readingBonusPerBook>0.2</readingBonusPerBook>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>
